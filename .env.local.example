# Google Analytics 4 measurement ID (G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=

# =============================================================================
# Rutherford Academy — Supabase auth + Stripe payments
# Copy this file to `.env.local` for local dev, and set the same values in
# Vercel Project Settings → Environment Variables for production.
# =============================================================================

# Feature flag — set to "true" locally to expose /academy/* and /account/*.
# Leave undefined (or "false") in production until the LMS is ready to launch.
NEXT_PUBLIC_ACADEMY_ENABLED=true

# Supabase (project: cawumjturiizzhzjtuiy)
# Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://cawumjturiizzhzjtuiy.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (dashboard.stripe.com)
# Use test keys (pk_test_…/sk_test_…) until ready to take real payments.
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs — create one Stripe Product per masterclass + one for the
# Academy Pass, then paste the `price_…` IDs here.
STRIPE_PRICE_CLOSED_LOOP=
STRIPE_PRICE_MEASURECOLOR_PRODUCTION=
STRIPE_PRICE_MEASURECOLOR_REPORTS=
STRIPE_PRICE_INTELLITRAX2=
STRIPE_PRICE_COLORLOOP_AI=
STRIPE_PRICE_OFFSET360=
STRIPE_PRICE_ACADEMY_PASS=
